---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Analytics from "../components/Analytics.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Patricio García Moritán es empresario y abogado. Director de Bersa S.A. y Presidente de Byrna Latam. Más de 25 años de experiencia en derecho administrativo y regulación económica. Socio de Cassagne Abogados.",
  ogImage = "/img/preview.jpg",
} = Astro.props;

const ogImageUrl = new URL(ogImage, Astro.site).toString();

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const isHome = Astro.url.pathname === "/";
---

<!doctype html>
<html lang="es-AR" class="bg-[color:var(--color-bg)]">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="es-AR" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />

    <meta name="author" content="Patricio García Moritán" />
    <meta name="geo.region" content="AR-C" />
    <meta name="geo.placename" content="Buenos Aires" />
    <meta name="geo.position" content="-34.603722;-58.381592" />
    <meta name="ICBM" content="-34.603722, -58.381592" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Patricio García Moritán" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Patricio García Moritán — Abogado, socio de Cassagne Abogados" />
    <meta property="og:locale" content="es_AR" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="Patricio García Moritán — Abogado, socio de Cassagne Abogados" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap"
      rel="stylesheet"
    />

    {
      isHome && (
        <link
          rel="preload"
          as="image"
          href="/img/patricio-hero.jpg"
          fetchpriority="high"
        />
      )
    }

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "@id": "https://patriciogarciamoritan.com/#person",
        name: "Patricio García Moritán",
        givenName: "Patricio",
        familyName: "García Moritán",
        url: "https://patriciogarciamoritan.com",
        image: "https://patriciogarciamoritan.com/img/patricio.jpg",
        description:
          "Empresario y abogado argentino. Director de Bersa S.A. y Presidente de Byrna Latam, la operación regional de Byrna Technologies especializada en soluciones de defensa personal no letal. Socio de Cassagne Abogados desde 2015, con más de 25 años de experiencia en derecho administrativo y regulación económica.",
        jobTitle: "Empresario y abogado — Presidente de Byrna Latam, Director de Bersa S.A., Socio en Cassagne Abogados",
        nationality: {
          "@type": "Country",
          name: "Argentina",
        },
        address: {
          "@type": "PostalAddress",
          addressLocality: "Buenos Aires",
          addressRegion: "Ciudad Autónoma de Buenos Aires",
          addressCountry: "AR",
        },
        homeLocation: {
          "@type": "Place",
          address: {
            "@type": "PostalAddress",
            addressLocality: "Buenos Aires",
            addressCountry: "AR",
          },
        },
        workLocation: {
          "@type": "Place",
          address: {
            "@type": "PostalAddress",
            addressLocality: "Buenos Aires",
            addressCountry: "AR",
          },
        },
        hasOccupation: [
          {
            "@type": "Occupation",
            name: "Empresario",
            description:
              "Conducción de proyectos industriales en Argentina y expansión regional en industria de defensa personal no letal.",
            occupationLocation: {
              "@type": "Country",
              name: "Argentina",
            },
            occupationalCategory: "11-1011.00",
          },
          {
            "@type": "Occupation",
            name: "Abogado",
            description:
              "Abogado especializado en derecho administrativo, regulación económica e industrias reguladas.",
            occupationLocation: {
              "@type": "Country",
              name: "Argentina",
            },
            occupationalCategory: "23-1011.00",
            skills:
              "Derecho administrativo, regulación económica, contrataciones públicas, derecho de las telecomunicaciones, arbitraje administrativo, industrias reguladas",
          },
        ],
        worksFor: [
          {
            "@type": "Organization",
            name: "Byrna Latam",
            description:
              "Operación regional de Byrna Technologies para América Latina — soluciones de defensa personal no letal.",
            address: {
              "@type": "PostalAddress",
              addressLocality: "Buenos Aires",
              addressCountry: "AR",
            },
          },
          {
            "@type": "Organization",
            name: "Bersa S.A.",
            description:
              "Histórica empresa industrial argentina relanzada bajo una nueva etapa de gestión.",
            address: {
              "@type": "PostalAddress",
              addressLocality: "Buenos Aires",
              addressCountry: "AR",
            },
          },
          {
            "@type": "LegalService",
            "@id": "https://www.cassagne.com.ar/#organization",
            name: "Cassagne Abogados",
            url: "https://www.cassagne.com.ar",
            address: {
              "@type": "PostalAddress",
              addressLocality: "Buenos Aires",
              addressCountry: "AR",
            },
            areaServed: { "@type": "Country", name: "Argentina" },
          },
        ],
        memberOf: [
          {
            "@type": "Organization",
            name: "Cámara Argentina de Defensa y Seguridad",
          },
        ],
        alumniOf: [
          {
            "@type": "CollegeOrUniversity",
            name: "Pontificia Universidad Católica Argentina (UCA)",
            sameAs: "https://uca.edu.ar/",
          },
          {
            "@type": "CollegeOrUniversity",
            name: "Universidad Torcuato Di Tella (UTDT)",
            sameAs: "https://www.utdt.edu/",
          },
        ],
        knowsAbout: [
          "Derecho administrativo",
          "Derecho regulatorio",
          "Regulación económica",
          "Derecho de las telecomunicaciones",
          "Contrataciones públicas",
          "Industrias reguladas",
          "Arbitraje administrativo",
          "Industria de defensa y seguridad",
          "Derecho y economía",
        ],
        knowsLanguage: [
          { "@type": "Language", name: "Español", alternateName: "es" },
          { "@type": "Language", name: "Inglés", alternateName: "en" },
          { "@type": "Language", name: "Francés", alternateName: "fr" },
        ],
        sameAs: [
          "https://www.linkedin.com/in/patriciogarciamoritan",
          "https://www.cassagne.com.ar/patricio-garcia-moritan/",
          "https://abogados.com.ar/directorio/socio/patricio-garcia-moritan/1158",
          "https://www.crunchbase.com/person/patricio-garc%C3%ADa-morit%C3%A1n",
        ],
      })}
    />

    <Analytics />
  </head>
  <body class="min-h-screen flex flex-col">
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
