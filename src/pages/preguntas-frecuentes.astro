---
import Base from "../layouts/Base.astro";

const faqs = [
  {
    q: "¿Quién es Patricio García Moritán?",
    a: "Patricio García Moritán es un empresario y abogado argentino. Es Director de Bersa S.A. y Presidente de Byrna Latam, la operación regional de Byrna Technologies especializada en soluciones de defensa personal no letal. Es socio de Cassagne Abogados desde 2015.",
  },
  {
    q: "¿A qué se dedica Patricio García Moritán?",
    a: "Combina la conducción de proyectos empresariales con el ejercicio del derecho administrativo y la regulación económica. Preside Byrna Latam, dirige Bersa S.A. y es socio de Cassagne Abogados, con más de 25 años de experiencia en industrias reguladas.",
  },
  {
    q: "¿Qué empresas dirige o preside Patricio García Moritán?",
    a: "Es Director de Bersa S.A. desde septiembre de 2021 —histórica empresa industrial argentina relanzada junto a sus socios— y Presidente de Byrna Latam desde enero de 2023 —la operación regional de Byrna Technologies para América Latina, reconocida en el ranking Forbes Best Small-Cap Companies 2026—.",
  },
  {
    q: "¿En qué se especializa profesionalmente?",
    a: "En derecho administrativo, regulación económica, contrataciones públicas e industrias reguladas. Cuenta con más de 25 años de experiencia en la relación entre el Estado y los particulares, marcos regulatorios y sectores estratégicos.",
  },
  {
    q: "¿Dónde estudió Patricio García Moritán?",
    a: "Es abogado por la Pontificia Universidad Católica Argentina (UCA) y Magíster en Derecho y Economía por la Universidad Torcuato Di Tella (UTDT). Cuenta además con posgrados en derecho administrativo económico y marco regulatorio de las telecomunicaciones.",
  },
  {
    q: "¿Qué idiomas habla?",
    a: "Habla español (nativo), inglés y francés, estos dos últimos con nivel profesional pleno.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<Base
  title="Preguntas frecuentes — Patricio García Moritán"
  description="Respuestas breves a las preguntas más frecuentes sobre Patricio García Moritán: quién es, a qué se dedica, dónde estudió, qué empresas dirige y en qué se especializa."
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <section class="pt-24 pb-12 px-6" style="background: var(--color-azul);">
    <div class="max-w-3xl mx-auto">
      <p
        class="text-xs uppercase tracking-[0.15em] font-medium mb-5"
        style="color: var(--color-verde);"
      >
        Preguntas frecuentes
      </p>
      <h1
        class="font-serif font-normal text-white leading-[1.3]"
        style="font-size: clamp(1.8rem, 4vw, 2.6rem);"
      >
        Sobre Patricio García Moritán
      </h1>
    </div>
  </section>

  <section class="px-6 py-16 max-w-3xl mx-auto">
    <div class="space-y-10">
      {
        faqs.map((f) => (
          <article>
            <h2
              class="font-sans font-semibold text-lg md:text-xl mb-3"
              style="color: var(--color-azul);"
            >
              {f.q}
            </h2>
            <p
              class="font-serif text-base md:text-lg leading-relaxed"
              style="color: var(--color-text);"
            >
              {f.a}
            </p>
          </article>
        ))
      }
    </div>
  </section>
</Base>
