---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("publicaciones", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const fmt = new Intl.DateTimeFormat("es-AR", {
  day: "numeric",
  month: "long",
  year: "numeric",
});

const canonical = new URL(Astro.url.pathname, Astro.site).toString();

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "@id": `${canonical}#article`,
  headline: post.data.titulo,
  description: post.data.bajada,
  image: new URL("/img/preview.jpg", Astro.site).toString(),
  datePublished: post.data.fecha.toISOString(),
  dateModified: post.data.fecha.toISOString(),
  inLanguage: "es-AR",
  articleSection: post.data.categoria,
  author: {
    "@type": "Person",
    "@id": "https://patriciogarciamoritan.com/#person",
    name: "Patricio García Moritán",
    url: "https://patriciogarciamoritan.com",
  },
  publisher: {
    "@type": "Person",
    "@id": "https://patriciogarciamoritan.com/#person",
    name: "Patricio García Moritán",
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonical,
  },
};
---

<Base
  title={
    post.data.titulo.includes("García Moritán")
      ? post.data.titulo
      : `${post.data.titulo} — Patricio García Moritán`
  }
  description={post.data.bajada}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <article>
    <!-- HERO -->
    <section
      class="relative overflow-hidden pt-24 pb-16 px-6"
      style="background: var(--color-azul);"
    >
      <div
        class="absolute -top-1/2 -right-[20%] w-[600px] h-[600px] rounded-full pointer-events-none"
        style="background: radial-gradient(circle, rgba(143,185,57,0.12) 0%, transparent 70%);"
      >
      </div>
      <div class="relative max-w-3xl mx-auto">
        <p
          class="text-xs uppercase tracking-[0.15em] font-medium mb-5"
          style="color: var(--color-verde);"
        >
          {post.data.categoria}
        </p>
        <h1
          class="font-serif font-normal text-white leading-[1.3] mb-6"
          style="font-size: clamp(1.8rem, 4vw, 2.6rem);"
        >
          {post.data.titulo}
        </h1>
        <div class="flex flex-wrap items-center gap-3 text-sm" style="color: rgba(255,255,255,0.7);">
          <span>{fmt.format(post.data.fecha)}</span>
          <span
            class="inline-block w-[3px] h-[3px] rounded-full"
            style="background: rgba(255,255,255,0.3);"></span>
          <span>{post.data.lectura} de lectura</span>
          {
            post.data.medio && (
              <>
                <span
                  class="inline-block w-[3px] h-[3px] rounded-full"
                  style="background: rgba(255,255,255,0.3);"
                />
                <span style="color: rgba(255,255,255,0.9);">
                  Fuente: <strong>{post.data.medio}</strong>
                </span>
              </>
            )
          }
        </div>
      </div>
    </section>

    <!-- BODY -->
    <section class="px-6 py-16 max-w-3xl mx-auto">
      <div class="prose-article">
        <Content />
      </div>

      {
        post.data.medio && post.data.medioUrl && (
          <div
            class="mt-12 p-6 rounded-lg"
            style="background: var(--color-bg); border-left: 3px solid var(--color-verde);"
          >
            <p class="text-xs uppercase tracking-[0.12em] mb-2" style="color: var(--color-verde); font-weight: 500;">
              Fuente original
            </p>
            <p class="text-sm leading-relaxed" style="color: var(--color-text);">
              Publicado originalmente en <strong>{post.data.medio}</strong>
              {post.data.medioFecha && (
                <>, el {fmt.format(post.data.medioFecha)}</>
              )}
              .
            </p>
            <a
              href={post.data.medioUrl}
              target="_blank"
              rel="noopener"
              class="inline-block mt-3 text-sm no-underline font-medium"
              style="color: var(--color-azul);"
            >
              → Leer el artículo completo en {post.data.medio}
            </a>
          </div>
        )
      }

      <!-- Author box -->
      <div
        class="mt-12 p-8 rounded-xl flex flex-col md:flex-row gap-6 items-start"
        style="background: var(--color-bg);"
      >
        <img
          src="/img/patricio-avatar.jpg"
          alt="Patricio García Moritán"
          width="64"
          height="64"
          loading="lazy"
          decoding="async"
          class="rounded-full w-16 h-16 object-cover flex-shrink-0"
        />
        <div>
          <h3
            class="font-sans font-semibold text-base mb-1"
            style="color: var(--color-azul);"
          >
            Patricio García Moritán
          </h3>
          <p class="text-sm leading-relaxed" style="color: var(--color-text-light);">
            Empresario y abogado argentino. Director de Bersa S.A. y Presidente
            de Byrna Latam. Socio de Cassagne Abogados. Magíster en Derecho y
            Economía (UTDT). Más de 25 años de experiencia en derecho
            administrativo y regulación económica.
          </p>
        </div>
      </div>
    </section>
  </article>
</Base>
